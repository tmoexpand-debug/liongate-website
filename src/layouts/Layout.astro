---
import Nav from '../components/Nav.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Lion Gate Pest Control — Professional pest and rodent control serving the Greater Los Angeles area. Family & pet friendly. 100% satisfaction guarantee.',
  image = '/hero-bg.jpg',
} = Astro.props;

const fullTitle = `${title} | Lion Gate Pest`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;

const cities = ['Los Angeles', 'Burbank', 'Pasadena', 'Glendale', 'Santa Monica', 'Beverly Hills', 'Hollywood', 'Westwood', 'Malibu', 'La Cañada Flintridge', 'San Fernando Valley'];

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://www.liongatepest.com/#business',
  name: 'Lion Gate Pest Control',
  description: 'Family-owned pest and rodent control serving the Greater Los Angeles area since 2005. Licensed & insured in California.',
  url: 'https://www.liongatepest.com',
  telephone: '+1-818-353-4800',
  email: 'contact@liongatepest.com',
  logo: 'https://www.liongatepest.com/logo-color.png',
  image: imageURL,
  priceRange: '$$',
  foundingDate: '2005',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Los Angeles',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  areaServed: cities.map((city) => ({ '@type': 'City', name: city })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '38',
    bestRating: '5',
    worstRating: '1',
  },
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="axH2pDmJm4Q3dJ5wHETmojgrNc2WxxESwCHv4iBRbtg" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lion Gate Pest Control" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Local business structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-86LC50V0SG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-86LC50V0SG');
    </script>
    <!-- Lead tracking: fire a GA4 'generate_lead' event on contact-intent clicks.
         Pushes straight to dataLayer (the canonical gtag mechanism) so it does not
         depend on a global gtag() function, which Astro scopes into a bundled module. -->
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        function track() { window.dataLayer.push(arguments); }
        document.addEventListener('click', function (e) {
          var link = e.target.closest && e.target.closest('a[href^="sms:"], a[href^="tel:"], a[href^="mailto:"]');
          if (!link) return;
          var href = link.getAttribute('href') || '';
          var method = href.lastIndexOf('sms:', 0) === 0 ? 'text'
                     : href.lastIndexOf('tel:', 0) === 0 ? 'call'
                     : 'email';
          track('event', 'generate_lead', {
            method: method,
            link_text: (link.textContent || '').trim().slice(0, 100),
            page_path: window.location.pathname
          });
        }, true);
      })();
    </script>
  </head>
  <body class="font-montserrat text-brand-body">
    <Nav />
    <main>
      <slot />
    </main>
    <PreFooterCTA />
    <Footer />
  </body>
</html>
