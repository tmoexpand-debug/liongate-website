---
import Nav from '../components/Nav.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Lion Gate Pest Control — Professional pest and rodent control serving the Greater Los Angeles area. Family & pet friendly. 100% satisfaction guarantee.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Lion Gate Pest</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-86LC50V0SG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-86LC50V0SG');
    </script>
  </head>
  <body class="font-montserrat text-brand-body">
    <Nav />
    <main>
      <slot />
    </main>
    <PreFooterCTA />
    <Footer />
  </body>
</html>
