---
import Layout from '../layouts/Layout.astro';

const reviews = [
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: 'I have been with this company for years. I had a very bad ant problem — once I started pest control with every other month service, we have not had any ants. Tom and Rick are great, they are honest. What I like about Lion Gate is they not only do pest, they also do termites and rodent work. I highly recommend Lion Gate.',
    rating: 5,
  },
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: 'Lion Gate has been treating our house for over 20 years. Our relatives use Lion Gate too. Very happy with them.',
    rating: 5,
  },
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: "It's been a year we are working with Lion Gate and they are doing a great job with great price. Tom was very friendly and did a great job today. I'm happy with the service.",
    rating: 5,
  },
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: 'Absolutely amazing service. Came in, discovered the problem, got it all done diligently. They explained all about what they use and how it will work. Answered any and all questions and were an absolute delight to correspond with. Would give a 10/10 if I could. Can\'t go wrong with Lions Gate.',
    rating: 5,
  },
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: 'New owner, Tom, provides the same excellent service as the previous owner. Very helpful and answered all my questions. Very satisfied.',
    rating: 5,
  },
  {
    name: 'Verified Google Review',
    location: 'Los Angeles, CA',
    text: 'We have been using Lion Gate for years and they are very nice, professional and great to work with!',
    rating: 5,
  },
];
---

<Layout title="Customer Reviews" description="See what Los Angeles homeowners say about Lion Gate Pest Control. Hundreds of satisfied customers across the Greater Los Angeles area.">

  <!-- Hero -->
  <section class="bg-brand-dark diagonal-stripe py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold text-white uppercase tracking-widest mb-4">
        Customer Reviews
      </h1>
      <p class="text-green-200 text-lg max-w-xl mx-auto">
        Don't take our word for it — hear from your neighbors across Los Angeles
      </p>
      <div class="flex justify-center gap-1 mt-6 text-3xl">
        {'★★★★★'.split('').map(s => <span class="text-yellow-400">{s}</span>)}
      </div>
      <p class="text-green-200 text-sm mt-2 font-semibold">5.0 ★ · 38 Google Reviews · Serving LA for Over 20 Years</p>
    </div>
  </section>

  <!-- Review Cards -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {reviews.map(review => (
          <div class="bg-brand-light rounded-2xl p-8 shadow-md border border-green-200 flex flex-col">
            <!-- Stars -->
            <div class="flex gap-1 mb-4">
              {'★★★★★'.split('').map(s => <span class="text-yellow-400 text-xl">{s}</span>)}
            </div>
            <!-- Review Text -->
            <p class="text-brand-body italic leading-relaxed flex-1 mb-6">"{review.text}"</p>
            <!-- Reviewer -->
            <div class="border-t border-green-200 pt-4">
              <p class="font-extrabold text-brand-dark uppercase tracking-wider text-sm">{review.name}</p>
              <p class="text-brand-body text-xs mt-1">{review.location}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center">
        <div class="bg-brand-light rounded-2xl p-8 border-2 border-green-300 max-w-2xl mx-auto">
          <div class="text-4xl mb-3">⭐</div>
          <h3 class="font-extrabold text-brand-dark uppercase tracking-widest text-lg mb-2">See All 38 Reviews on Google</h3>
          <p class="text-brand-body text-sm mb-6">
            We have a 5.0 rating on Google. Check our listing to read all of our reviews from your neighbors across Los Angeles.
          </p>
          <a href="https://share.google/156d9QWu5Z7cPsNIA" target="_blank" rel="noopener noreferrer" class="btn-sms">
            Read Our Google Reviews →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / Trust -->
  <section class="bg-brand-dark py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl font-extrabold text-white mb-1">100%</div>
          <div class="text-green-300 text-sm font-bold uppercase tracking-wider">Satisfaction Guarantee</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-white mb-1">40+</div>
          <div class="text-green-300 text-sm font-bold uppercase tracking-wider">Pest Types Treated</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-white mb-1">38</div>
          <div class="text-green-300 text-sm font-bold uppercase tracking-wider">5-Star Google Reviews</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-white mb-1">LA</div>
          <div class="text-green-300 text-sm font-bold uppercase tracking-wider">Area Specialists</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-heading mb-4">Ready To Join Our Happy Customers?</h2>
      <p class="text-brand-body mb-8 leading-relaxed">
        Text <strong>SAVE50</strong> to <strong>(818) 353-4800</strong> and get 50% off your first service. Join hundreds of satisfied Los Angeles homeowners.
      </p>
      <a href="sms:+18183534800&body=SAVE50" class="btn-sms-lg">
        Text SAVE50 — Get 50% Off First Service
      </a>
    </div>
  </section>

</Layout>
