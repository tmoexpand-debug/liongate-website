---
import Layout from '../layouts/Layout.astro';

const cities = [
  'Los Angeles', 'Burbank', 'Pasadena', 'Glendale', 'Santa Monica',
  'Beverly Hills', 'Hollywood', 'Westwood', 'Malibu', 'La Cañada & Foothills',
  'San Fernando Valley'
];
---

<Layout title="Contact Us" description="Contact Lion Gate Pest Control — Los Angeles pest and rodent control. Call or text (818) 353-4800. Serving the Greater Los Angeles area.">

  <!-- Hero -->
  <section class="bg-brand-dark diagonal-stripe py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold text-white uppercase tracking-widest mb-4">
        Contact Us
      </h1>
      <p class="text-green-200 text-lg max-w-xl mx-auto">
        Ready to get rid of pests? Reach out and we'll get you scheduled fast.
      </p>
    </div>
  </section>

  <!-- Contact info + CTAs -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-extrabold text-brand-dark uppercase tracking-widest mb-8">Get In Touch</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-dark rounded-xl flex items-center justify-center text-white text-xl flex-shrink-0">📞</div>
              <div>
                <h3 class="font-extrabold text-brand-dark uppercase tracking-wider text-sm mb-1">Phone</h3>
                <a href="tel:+18183534800" class="text-brand-medium font-bold text-lg hover:text-brand-dark transition-colors">(818) 353-4800</a>
                <p class="text-brand-body text-sm mt-1">Call or text anytime</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-dark rounded-xl flex items-center justify-center text-white text-xl flex-shrink-0">✉️</div>
              <div>
                <h3 class="font-extrabold text-brand-dark uppercase tracking-wider text-sm mb-1">Email</h3>
                <a href="mailto:contact@liongatepest.com" class="text-brand-medium font-bold hover:text-brand-dark transition-colors">contact@liongatepest.com</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-dark rounded-xl flex items-center justify-center text-white text-xl flex-shrink-0">🕐</div>
              <div>
                <h3 class="font-extrabold text-brand-dark uppercase tracking-wider text-sm mb-1">Business Hours</h3>
                <p class="text-brand-body font-semibold">Monday – Friday: 9am – 5pm</p>
                <p class="text-brand-body text-sm">Saturday–Sunday: Closed</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-brand-dark rounded-xl flex items-center justify-center text-white text-xl flex-shrink-0">📍</div>
              <div>
                <h3 class="font-extrabold text-brand-dark uppercase tracking-wider text-sm mb-1">Service Area</h3>
                <p class="text-brand-body font-semibold">Greater Los Angeles Area</p>
                <p class="text-brand-body text-sm">Including San Fernando Valley &amp; surrounding cities</p>
              </div>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="mt-10 space-y-4">
            <a href="sms:+18183534800&body=SAVE50" class="btn-sms-lg w-full block text-center">
              📱 Text SAVE50 — Get 50% Off
            </a>
            <a href="mailto:contact@liongatepest.com" class="btn-sms w-full block text-center bg-white text-brand-dark border-2 border-brand-dark hover:bg-brand-light">
              ✉️ Email Us
            </a>
            <a href="tel:+18183534800" class="btn-sms w-full block text-center bg-white text-brand-dark border-2 border-brand-dark hover:bg-brand-light">
              📞 Call (818) 353-4800
            </a>
          </div>
        </div>

        <!-- Map -->
        <div>
          <h2 class="text-2xl font-extrabold text-brand-dark uppercase tracking-widest mb-8">Service Area Map</h2>
          <div class="rounded-2xl overflow-hidden shadow-lg border-2 border-green-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d211282.36557258!2d-118.60467!3d34.20!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2955a67654d2b%3A0x4fa3eb4c23c2db1a!2sSan%20Fernando%20Valley%2C%20CA!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="380"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="San Fernando Valley Service Area"
            ></iframe>
          </div>
          <p class="text-brand-body text-sm mt-3 text-center font-semibold uppercase tracking-wider">
            Serving the Greater Los Angeles Area
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Cities -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="section-heading mb-4">Cities We Serve</h2>
      <p class="section-subheading mb-10">Proudly serving homeowners throughout the Los Angeles area</p>
      <div class="flex flex-wrap justify-center gap-3">
        {cities.map(city => (
          <span class="bg-white text-brand-dark font-bold uppercase tracking-wider text-sm px-5 py-3 rounded-full shadow-sm border border-green-200">
            {city}
          </span>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-brand-body font-semibold mb-4">Don't see your city? Give us a call — we may still service your area.</p>
        <a href="tel:+18183534800" class="btn-sms">
          Call (818) 353-4800
        </a>
      </div>
    </div>
  </section>

</Layout>
