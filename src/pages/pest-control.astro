---
import Layout from '../layouts/Layout.astro';

const included = [
  'Ants (all species)',
  'Cockroaches',
  'Spiders',
  'Fleas',
  'Flies & Gnats',
  'Wasps & Hornets',
  'Mosquitoes',
  'Beetles',
  'Silverfish',
  'Earwigs',
  'Centipedes & Millipedes',
  'Stink Bugs',
  'Crickets',
  'Aphids',
  'Box Elder Bugs',
  'Pill Bugs',
];

const excluded = [
  'Termites (separate treatment required)',
  'Bed Bugs (specialized treatment available)',
  'Wildlife removal',
  'Structural damage repair',
];

const schedule = [
  { season: 'Spring', focus: 'Ant colonies, wasp nest prevention, perimeter barrier' },
  { season: 'Summer', focus: 'Mosquitoes, flies, hornets, outdoor activity pests' },
  { season: 'Fall', focus: 'Indoor pest-proofing, spiders, crickets entering home' },
  { season: 'Winter', focus: 'Cockroaches, rodent-adjacent pests, interior treatments' },
];
---

<Layout title="Pest Control Services" description="Professional pest control services in Los Angeles. We treat 40+ pests including ants, cockroaches, spiders, wasps, and more. 100% satisfaction guarantee.">

  <!-- Guarantee Banner -->
  <div class="bg-brand-dark diagonal-stripe py-5 px-4">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white font-bold uppercase tracking-wider text-center sm:text-left">
        🛡️ If pests return between treatments — we come back <span class="text-yellow-300">FREE</span>
      </p>
      <a href="sms:+18183534800&body=SAVE50" class="btn-sms text-sm py-2 px-6 flex-shrink-0">
        Claim 50% Off Now
      </a>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-brand-light py-16 px-4 border-b-4 border-brand-medium">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-brand-medium font-bold uppercase tracking-widest text-sm mb-2">Los Angeles Pest Control</p>
      <h1 class="text-4xl md:text-6xl font-extrabold text-brand-dark uppercase tracking-widest mb-6">
        Pest Control
      </h1>
      <p class="text-brand-body text-lg max-w-2xl mx-auto leading-relaxed mb-8">
        Comprehensive pest management for Los Angeles homeowners. We eliminate the bugs and keep them away with our quarterly treatment schedule and free re-treatment guarantee.
      </p>
      <a href="sms:+18183534800&body=SAVE50" class="btn-sms-lg">
        Get a Free Quote
      </a>
    </div>
  </section>

  <!-- Included / Excluded -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="section-heading mb-12">What's Included</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Included -->
        <div class="bg-brand-light rounded-2xl p-8 border-2 border-brand-medium">
          <h3 class="text-brand-dark font-extrabold uppercase tracking-widest text-lg mb-6 flex items-center gap-2">
            <span class="text-brand-medium text-2xl">✓</span> We Treat
          </h3>
          <ul class="space-y-3">
            {included.map(item => (
              <li class="flex items-center gap-3 text-brand-body font-semibold text-sm">
                <span class="text-brand-medium font-bold flex-shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Excluded -->
        <div>
          <div class="bg-red-50 rounded-2xl p-8 border-2 border-red-200 mb-6">
            <h3 class="text-red-700 font-extrabold uppercase tracking-widest text-lg mb-6 flex items-center gap-2">
              <span class="text-red-500 text-2xl">✗</span> Not Included
            </h3>
            <ul class="space-y-3">
              {excluded.map(item => (
                <li class="flex items-center gap-3 text-red-700 font-semibold text-sm">
                  <span class="text-red-500 font-bold flex-shrink-0">✗</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <!-- Custom treatments note -->
          <div class="bg-brand-dark rounded-2xl p-6">
            <h4 class="text-white font-extrabold uppercase tracking-widest text-sm mb-3">Custom Treatments Available</h4>
            <p class="text-green-200 text-sm leading-relaxed">
              Have a specific pest problem not listed? We offer custom treatment plans for bed bugs, termite prevention, and other specialty pests. Contact us to discuss your situation.
            </p>
            <a href="sms:+18183534800&body=SAVE50" class="inline-block mt-4 text-yellow-300 font-bold text-sm uppercase tracking-wider hover:text-white transition-colors">
              Ask About Custom Plans →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quarterly Schedule -->
  <section class="bg-brand-light py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="section-heading mb-4">Quarterly Treatment Schedule</h2>
      <p class="section-subheading mb-12">Year-round protection tailored to seasonal pest activity</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {schedule.map((s, i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-green-200 text-center">
            <div class="w-12 h-12 bg-brand-dark rounded-full flex items-center justify-center text-white font-extrabold text-sm mx-auto mb-3 uppercase tracking-wide">
              Q{i + 1}
            </div>
            <h3 class="font-extrabold text-brand-dark uppercase tracking-wider text-base mb-2">{s.season}</h3>
            <p class="text-brand-body text-xs leading-relaxed">{s.focus}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <a href="sms:+18183534800&body=SAVE50" class="btn-sms-lg">
          Get a Quote — 50% Off First Treatment
        </a>
        <p class="text-brand-body text-sm mt-4 font-semibold">Family Owned · Licensed &amp; Insured in California</p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="section-heading mb-12">Our Treatment Process</h2>
      <div class="space-y-6">
        <div class="flex gap-6 items-start">
          <div class="w-10 h-10 bg-brand-dark rounded-full flex items-center justify-center text-white font-extrabold flex-shrink-0">1</div>
          <div>
            <h3 class="font-extrabold text-brand-dark uppercase tracking-wider mb-1">Inspection</h3>
            <p class="text-brand-body text-sm leading-relaxed">Our technician inspects interior and exterior areas to identify pest activity, entry points, and environmental factors contributing to the problem.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-10 h-10 bg-brand-dark rounded-full flex items-center justify-center text-white font-extrabold flex-shrink-0">2</div>
          <div>
            <h3 class="font-extrabold text-brand-dark uppercase tracking-wider mb-1">Treatment</h3>
            <p class="text-brand-body text-sm leading-relaxed">We apply EPA-registered products to targeted areas — perimeter, entry points, nesting areas, and high-activity zones. Interior treatments use products safe around family and pets.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-10 h-10 bg-brand-dark rounded-full flex items-center justify-center text-white font-extrabold flex-shrink-0">3</div>
          <div>
            <h3 class="font-extrabold text-brand-dark uppercase tracking-wider mb-1">Follow-Up &amp; Monitoring</h3>
            <p class="text-brand-body text-sm leading-relaxed">We schedule quarterly follow-up visits to maintain protection. If pests return between visits, we come back at no charge — that's our guarantee.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
