---
import Layout from '../layouts/Layout.astro';

const pestsLeft = ['Ants', 'Aphids', 'Beetles', 'Box Elder Bugs', 'Centipedes', 'Cockroaches', 'Fleas'];
const pestsRight = ['Flies', 'Mice/Rats', 'Mites', 'Mosquitoes', 'Spiders', 'Ticks', 'Wasps'];

const allPests = [
  'Ants', 'Aphids', 'Bed Bugs', 'Beetles', 'Box Elder Bugs', 'Carpenter Ants', 'Carpenter Bees',
  'Centipedes', 'Cicadas', 'Cockroaches', 'Crickets', 'Earwigs', 'Fire Ants', 'Fleas',
  'Flies', 'Fruit Flies', 'Gnats', 'Ground Beetles', 'Hornets', 'House Flies',
  'Mice', 'Millipedes', 'Mites', 'Mosquitoes', 'Moths', 'Pill Bugs', 'Rats',
  'Silverfish', 'Slugs', 'Snails', 'Sowbugs', 'Spiders', 'Stink Bugs',
  'Termites (preventive)', 'Ticks', 'Wasps', 'Weevils', 'Whiteflies', 'Yellow Jackets', 'Zika Mosquitoes'
];

const faqs = [
  {
    q: 'Do you handle rodent problems like mice and rats?',
    a: 'Yes! We offer dedicated Rodent Control services including inspection, bait stations, exclusion, and follow-up visits. Rodents can carry disease and cause serious property damage — we take it seriously.'
  },
  {
    q: 'How soon can you schedule a visit?',
    a: 'In most cases we can schedule your first treatment within 24–48 hours. We serve the Greater Los Angeles area and try to accommodate your schedule as quickly as possible.'
  },
  {
    q: 'Do you treat during the winter months?',
    a: 'Absolutely. Pests don\'t take the winter off, and neither do we. Many species like cockroaches, rodents, and spiders actually seek warmth indoors during cooler months. Year-round protection is the best approach.'
  },
  {
    q: 'What is your satisfaction guarantee?',
    a: 'We stand behind our work 100%. If you see pests between scheduled treatments, call us and we\'ll return for a free re-treatment. Your peace of mind is our priority.'
  },
  {
    q: 'How is pricing determined?',
    a: 'Pricing depends on your home size, pest type, and treatment plan. Text us SAVE50 to get a quote and claim 50% off your first service. No hidden fees — we\'re transparent about costs upfront.'
  },
  {
    q: 'Are your treatments safe for pets and children?',
    a: 'Yes. We use EPA-registered products and apply them responsibly. We\'ll always advise you on any brief re-entry times if needed. Our technicians are trained to minimize exposure to your family and pets.'
  },
];
