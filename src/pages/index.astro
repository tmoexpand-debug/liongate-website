<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const isOpen = answer.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
      document.querySelectorAll('.faq-toggle').forEach(b => b.classList.remove('open'));
      // Open this one if it was closed
      if (!isOpen) {
        answer.classList.add('open');
        btn.classList.add('open');
      }
    });
  });

  // Pest Modal
  const modal = document.getElementById('pest-modal');
  document.getElementById('open-pest-modal')?.addEventListener('click', () => {
    modal?.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  document.getElementById('close-pest-modal')?.addEventListener('click', () => {
    modal?.classList.remove('open');
    document.body.style.overflow = '';
  });
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
</script>
